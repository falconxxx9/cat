// the use of enumerated data types (enums)

// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract OrderStatus {
constructor() payable {}
    // Enum for order stages
    enum Status { Placed, Shipped, Delivered }

    Status public orderStatus;

    // Update order status
    function updateStatus(Status _status) public returns (Status) {
        orderStatus = _status;
        return orderStatus;
    }

    // Get current order status
    function getStatus() public view returns (Status) {
        return orderStatus;
    }
}


//2. Program for Struct (Employee Record System)
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;
contract EmployeeRecord {
constructor() payable {}

    // Struct for employee details
    struct Employee {
        uint id;
        string name;
        uint salary;
    }

    Employee public emp;

    // Set employee details
    function setEmployee(
        uint _id,
        string memory _name,
        uint _salary
    ) public returns (uint, string memory, uint) {
        emp = Employee(_id, _name, _salary);
        return (emp.id, emp.name, emp.salary);
    }

    // Get employee details
    function getEmployee()
        public
        view
        returns (uint, string memory, uint)
    {
        return (emp.id, emp.name, emp.salary);
    }
}



//Program for Mapping (Bank Balance System)
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract Bank {
constructor() payable {}

    // Mapping for account balances
    mapping(address => uint) public balances;

    // Deposit money
    function deposit() public payable returns (uint) {
        balances[msg.sender] += msg.value;
        return balances[msg.sender];
    }

    // Check balance
    function getBalance() public view returns (uint) {
        return balances[msg.sender];
    }
}



